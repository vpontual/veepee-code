# ─── Ollama Connection (required) ─────────────────────────────────────────────
# Works with a standard Ollama server OR an Ollama Fleet Manager proxy
VEEPEE_CODE_PROXY_URL=http://localhost:11434
# VEEPEE_CODE_DASHBOARD_URL=http://localhost:3334  # Only if using Ollama Fleet Manager

# ─── Model Preferences (optional — auto-discovered if not set) ────────────────
# VEEPEE_CODE_MODEL=              # Override default model (e.g. qwen3.5:35b)
VEEPEE_CODE_AUTO_SWITCH=true      # Enable dynamic model switching
VEEPEE_CODE_MAX_TURNS=50          # Max agent turns per interaction
VEEPEE_CODE_MAX_MODEL_SIZE=40     # Max model size in billions (skip 70B+ slugs)
VEEPEE_CODE_MIN_MODEL_SIZE=6      # Min model size (skip tiny models for coding)

# ─── Home Assistant (optional) ────────────────────────────────────────────────
# HA_URL=http://your-ha-server:8123
# HA_TOKEN=your_long_lived_access_token

# ─── Mastodon (optional) ──────────────────────────────────────────────────────
# MASTODON_URL=https://your.mastodon.instance
# MASTODON_TOKEN=your_access_token

# ─── Spotify (optional) ───────────────────────────────────────────────────────
# Create app at https://developer.spotify.com/dashboard
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REFRESH_TOKEN=

# ─── Google Workspace (optional) ──────────────────────────────────────────────
# Create OAuth2 credentials at https://console.cloud.google.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# ─── News (optional) ──────────────────────────────────────────────────────────
# NEWSFEED_URL=http://localhost:3333  # AI-optimized newsfeed API

# ─── Web Search (optional) ────────────────────────────────────────────────────
# SearXNG — free self-hosted metasearch: https://docs.searxng.org
# SEARXNG_URL=http://localhost:8888
